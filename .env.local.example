# Copy this file to .env.local and paste your real key.
# Get one at https://console.anthropic.com  (Settings -> API Keys)
# NEVER commit .env.local — it is gitignored on purpose.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Rate limiting (Upstash Redis, free tier). Get both from your Upstash
# database page at https://console.upstash.com  ->  REST API section.
# If these are left blank, the app still runs but rate limiting is OFF.
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
